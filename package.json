{
  "name": "@ayocore/exceljs",
  "version": "5.0.3",
  "description": "Lightweight Node.js-only fork of ExcelJS for server-side XLSX generation.",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Guyon Roche (original), Ayocore (fork)",
    "email": "guyon@live.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ayocore/exceljs.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./excel.js",
  "types": "./index.d.ts",
  "files": [
    "lib",
    "excel.js",
    "LICENSE",
    "README.md",
    "index.ts",
    "index.d.ts"
  ],
  "scripts": {
    "test": "npm run test:full",
    "test:full": "npm run test:unit && npm run test:integration && npm run test:end-to-end",
    "test:unit": "mocha --require spec/config/setup --require spec/config/setup-unit spec/unit --recursive",
    "test:integration": "mocha --require spec/config/setup spec/integration --recursive",
    "test:end-to-end": "mocha --require spec/config/setup spec/end-to-end --recursive",
    "test:manual": "node spec/manual/app.js",
    "test:typescript": "mocha -r ts-node/register spec/typescript/**/*.spec.ts",
    "lint": "eslint .",
    "lint:fix": "prettier --write . && eslint --fix .",
    "lint:staged": "lint-staged",
    "benchmark": "node --expose-gc benchmark",
    "benchmark:debug": "node --expose-gc --inspect-brk --trace-deopt benchmark"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "xlsx",
    "json",
    "csv",
    "excel",
    "font",
    "border",
    "fill",
    "number",
    "format",
    "number format",
    "alignment",
    "office",
    "spreadsheet",
    "workbook",
    "defined names",
    "data validations",
    "rich text",
    "in-cell format",
    "outlineLevel",
    "views",
    "frozen",
    "split",
    "pageSetup"
  ],
  "dependencies": {
    "archiver": "^7.0.1",
    "jszip": "^3.10.1",
    "saxes": "^5.0.1",
    "tmp": "^0.2.3",
    "unzipper": "^0.12.3",
    "uuid": "^8.3.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^4.2.0",
    "chai-datetime": "^1.7.0",
    "chai-xml": "^0.4.1",
    "dirty-chai": "^2.0.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "express": "^4.16.4",
    "got": "^11.8.6",
    "husky": "^4.3.0",
    "lint-staged": "^10.2.13",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "serialize-javascript": "^6.0.2"
  }
}
