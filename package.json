{
  "name": "exceljs",
  "version": "4.4.0",
  "description": "Excel Workbook Manager - Read and Write xlsx and csv Files.",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Guyon Roche",
    "email": "guyon@live.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/exceljs/exceljs.git"
  },
  "engines": {
    "node": ">=8.3.0"
  },
  "main": "./excel.js",
  "browser": "./dist/exceljs.min.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "lib",
    "excel.js",
    "LICENSE",
    "README.md",
    "README_zh.md",
    "index.ts",
    "index.d.ts"
  ],
  "scripts": {
    "test": "npm run test:full",
    "test:es5": "export EXCEL_BUILD=es5 && npm run test:full",
    "test:full": "npm run build && npm run test:unit && npm run test:integration && npm run test:end-to-end",
    "test:version": "npm run build && npm run test:unit && npm run test:integration && npm run test:end-to-end && npm run test:dist",
    "test:all": "npm run test:native && npm run test:es5",
    "test:native": "npm run test:full",
    "test:unit": "mocha --require spec/config/setup --require spec/config/setup-unit spec/unit --recursive",
    "test:integration": "mocha --require spec/config/setup spec/integration --recursive",
    "test:end-to-end": "mocha --require spec/config/setup spec/end-to-end --recursive",
    "test:unit:es5": "export EXCEL_BUILD=es5 && npm run test:unit",
    "test:integration:es5": "export EXCEL_BUILD=es5 && npm run test:integration",
    "test:end-to-end:es5": "export EXCEL_BUILD=es5 && npm run test:end-to-end",
    "test:dist": "mocha --require spec/config/setup spec/dist --recursive",
    "test:manual": "node spec/manual/app.js",
    "test:typescript": "mocha -r ts-node/register spec/typescript/**/*.spec.ts",
    "clean-build": "npm run clean && npm run build",
    "lint": "eslint .",
    "lint:fix": "prettier --write . && eslint --fix .",
    "lint:staged": "lint-staged",
    "clean": "rm -rf build/ && rm -rf dist",
    "benchmark": "node --expose-gc benchmark",
    "benchmark:debug": "node --expose-gc --inspect-brk --trace-deopt benchmark",
    "build": "npm run clean && npm run build:babel && npm run build:bundle && npm run build:bare && npm run build:minify && npm run build:copy",
    "build:babel": "babel lib/ -d build/lib --source-maps",
    "build:bundle": "node esbuild.js lib/exceljs.browser.js dist/exceljs.js",
    "build:bare": "node esbuild.js lib/exceljs.bare.js dist/exceljs.bare.js",
    "build:minify": "terser dist/exceljs.js -o dist/exceljs.min.js --source-map \"content=dist/exceljs.js.map,url=exceljs.min.js.map\" && terser dist/exceljs.bare.js -o dist/exceljs.bare.min.js --source-map \"content=dist/exceljs.bare.js.map,url=exceljs.bare.min.js.map\"",
    "build:copy": "mkdir -p dist/es5 && cp -r build/lib/ dist/es5/ && cp build/lib/exceljs.nodejs.js dist/es5/index.js && cp LICENSE dist/",
    "install-build": "npm install && npm run build",
    "preversion": "npm run clean && npm run build && npm run test:version",
    "postversion": "git push --no-verify && git push --tags --no-verify"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "xlsx",
    "json",
    "csv",
    "excel",
    "font",
    "border",
    "fill",
    "number",
    "format",
    "number format",
    "alignment",
    "office",
    "spreadsheet",
    "workbook",
    "defined names",
    "data validations",
    "rich text",
    "in-cell format",
    "outlineLevel",
    "views",
    "frozen",
    "split",
    "pageSetup"
  ],
  "dependencies": {
    "archiver": "^5.0.0",
    "dayjs": "^1.8.34",
    "fast-csv": "^4.3.1",
    "jszip": "^3.10.1",
    "readable-stream": "^3.6.0",
    "saxes": "^5.0.1",
    "tmp": "^0.2.3",
    "unzipper": "^0.10.11",
    "uuid": "^8.3.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.10.5",
    "@babel/core": "^7.11.4",
    "@babel/preset-env": "^7.11.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "buffer": "^6.0.3",
    "chai": "^4.2.0",
    "chai-datetime": "^1.7.0",
    "chai-xml": "^0.4.1",
    "core-js": "^3.6.5",
    "dirty-chai": "^2.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "events": "^3.3.0",
    "express": "^4.16.4",
    "got": "^11.8.6",
    "husky": "^4.3.0",
    "lint-staged": "^10.2.13",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "regenerator-runtime": "^0.13.7",
    "sax": "^1.2.4",
    "stream-browserify": "^3.0.0",
    "terser": "^5.46.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "util": "^0.12.5"
  },
  "overrides": {
    "serialize-javascript": "^6.0.2"
  }
}
